(ns back-office-switch-report.util.cache
  (:require [clojure.core.cache :as cache]))

(def the-cache (atom (cache/ttl-cache-factory {} :ttl 30000)))

(defn hit-or-miss
  [c k v]
  (if (cache/has? c k)
      (cache/hit c k)
      (cache/miss c k (v))))

(defn get-cached-value
  [k v]
  (k (swap! the-cache hit-or-miss k v)))
