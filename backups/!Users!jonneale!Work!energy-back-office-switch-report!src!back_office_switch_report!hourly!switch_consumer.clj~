(ns back-office-switch-report.hourly.switch-consumer
  (:require
            [langohr.core      :as rmq]
            [langohr.channel   :as lch]
            [langohr.queue     :as lq]
            [langohr.consumers :as lc]
            [langohr.basic     :as lb]
            [clojure.data.json              :as json]
            [back-office-switch-report.import.etl :as etl])
  (:use     [korma.core]
            [clojure.pprint]
            [back-office-switch-report.db.entities]))

(def ^{:const true}
  default-exchange-name "")

(defn insert-switch
  [message]
  (do
    (println "Got a switch")
    (let [data (json/read-json message)]
      (exec-raw ["INSERT INTO switches values (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)" (first (etl/transform [data]))]))))

(defn message-handler
  [ch {:keys [content-type delivery-tag type] :as meta} ^bytes payload]
  (let [message (String. payload "UTF-8")]
    (insert-switch message)))

(defn consume
  []
  (let [conn  (rmq/connect {:host "127.0.0.1", :port 5672, :username "guest", :vhost "/", :password "guest"})
        ch    (lch/open conn)
        qname "switches"
        subscriber-tag (lc/subscribe ch qname message-handler :auto-ack true)]
    subscriber-tag))