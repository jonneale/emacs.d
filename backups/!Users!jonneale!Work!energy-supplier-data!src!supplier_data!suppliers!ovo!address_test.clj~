(ns supplier-data.supplier.ovo.address-test
  (:require  [supplier-data.db.switches-db             :as sdb]
             [clojure.java.io :as io]
             [supplier-data.suppliers.ovo.translation :as t]
             [supplier-data.domain.switch-instruction :as si]
             [supplier-data.domain.overrides           :as overrides]
             [supplier-data.util.dates                 :as dates])
  (:use     [clojure.tools.cli :only (cli)]
            [clojure.data.json :only (read-json)]))


(defn- generate-supplier-data
  [switches]
  (flatten (map #(assoc (t/translate-instruction (si/decrypt (:instruction %))
                                                 (:overrides %))
                   :address-info
                   (si/supply-address (si/decrypt (:instruction %))))
                switches)))

(defn- get-switches-ready-for-batching
  [date]
  (overrides/assoc-overrides (sdb/get-switches-ready-for-batching "ovo" date)))

(defn print-address-info
  [switches]
  (doseq [switch-instruction switches]
    (println (:address-info switch-instruction))
    (println "-----------------------------------")
    (for [k [:UNIT_TYPE :UNIT_NUMBER :HOUSE_NUMBER :FREE_FORMAT :BUILDING_NAME :FLOOR_TYPE
             :FLOOR_NUMBER :STREET_NAME :LOCALITY :POST_TOWN :POSTCODE]]
      (println (str k " " (k switch-instruction))))))

(defn load-switch-instruction
  [date]
  (-> date
      get-switches-ready-for-batching
      generate-supplier-data
      print-address-info))

(defn -main
  [& args]
  (let [[options args banner] (cli args
                                   ["-d" "--date" "The date of the switches"])]
    (when (or (:help options)
              (not (:filepath options)))
      (println banner)
      (System/exit 0))    
    (println "Get ovo switches on " (options :date))
    (let [switch-date     (options :date)] 
      (load-switch-instruction (dates/parse-date switch-date)))))