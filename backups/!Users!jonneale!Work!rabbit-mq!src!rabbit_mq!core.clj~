(defn main
  [& args]
  (let [conn  (rmq/connect {:host "127.0.0.1", :port 5672, :username "guest", :vhost "/", :password "guest"})
        ch    (lch/open conn)
        qname "switches"]
    (println (format "[main] Connected. Channel id: %d" (.getChannelNumber ch)))
    (lq/declare ch qname :exclusive false :auto-delete false)
    (start-consumer conn ch qname)
    (lb/publish ch default-exchange-name qname "Hello!" :content-type "text/plain" :type "")
    (Thread/sleep 2000)
    (println "[main] Disconnecting...")
    (rmq/close ch)
    (rmq/close conn)))

(defn consume
  []
  (let [conn  (rmq/connect {:host "127.0.0.1", :port 5672, :username "guest", :vhost "/", :password "guest"})
        ch    (lch/open conn)
        qname "switches"]
    (lc/subscribe ch qname message-handler :auto-ack true)))