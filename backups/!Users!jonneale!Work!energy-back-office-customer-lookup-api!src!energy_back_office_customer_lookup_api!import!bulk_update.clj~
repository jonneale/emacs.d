
(defn update-rows
  [switches])

(defn daily-import
  [iso-date & [remove]]
  (when remove (delete-switches-on iso-date))
  (-> (download-switches iso-date)
      transform-data
      replace-nulls
      update-rows))

(defn -main [& args]
  (let [[{:keys [date remove] :as options} args banner] (cli args
                                   ["-d" "--date" "The date of the switch to load from switch management as an iso date (eg. 2012-01-28)"]
                                   ["-r" "--[no-]remove" "If specified the switches on the specified date will be removed before the switches are loaded" :flag true :default false])]
    (when (or (:help options)
              (not date))
      (println banner)
      (System/exit 0))
    (println "Importing switches from: " date)
    (daily-import date remove)))