(ns supplier-data.suppliers.ovo.address
  (:require             [clojure.string :as string]))

(defn unit-type
  [{:keys [line_1]}]
  (let [line-1 (string/lower-case line_1)]
    (cond (re-find #"flat " line-1)
          "FLAT NO"
          (re-find #"apartment " line-1)
          "APARTMENT"
          (re-find #"unit " line-1)
          "UNIT NO"
          (re-find #"building " line-1)
          "BUILDING"
          (re-find #"suite " line-1)
          "SUITE")))

(defn unit-number
  [{:keys [line_1] :as address}]
  (when ((comp not string/blank? unit-type) address)
    (last (re-matches #"(flat|apartment|unit|building|suite) ([^\,]*).*" (string/lower-case line_1)))))



(defn building-name
  [{:keys [line_1 line_2 house_number address_manually_entered] :as address}]
  (cond
   (and address_manually_entered (re-matches #"^\D+$" house_number))
   house_number
   (and (not (unit-type address)) (re-matches #"^\D+$" line_1) (not address_manually_entered))
   line_1
   (and (unit-type address) (re-matches #"^\D+$" line_2) (not address_manually_entered))
   line_2))

(defn house-number
  [{:keys [house_number line_1 line_2 line_3] :as address}]
  (let [potential-lines (if (unit-type address) [line_2 line_3] [line_1 line_2 line_3])
        house-number-line (first (filter #(re-find #"^\d+" %) potential-lines))]
    (if house-number-line
      (second (re-matches #"^(\d*[^\s,]*).*" house-number-line))
      (when (re-matches #"[1-9]+[a-zA-Z]*" (string/trim house_number))
        (string/trim house_number)))))

(defn street-name
  [{:keys [line_1 line_2 line_3] :as address}]
  (string/trim (let [building (building-name address)
                     street-address (cond
                                     (and (string/blank? line_2) (string/blank? line_3))
                                     line_1
                                     (and (string/blank? building) (string/blank? (unit-type address)))
                                      line_1
                                      (= building line_2)
                                      line_3
                                      :else
                                      line_2)]
                 (string/replace street-address (or (house-number address) "") ""))))

(defn locality
  [{:keys [line_2 line_3] :as address}]
  (let [potential-locality (if (and (not (unit-type address)) (string/blank? line_3 ))
                             line_2
                             line_3)]
    (when (not (re-find (re-pattern (street-name address)) potential-locality)) potential-locality)))