(ns energy-pnl.costs.offline-partners-costs
  (:use clojure.test)
  (:require [energy-pnl.costs.offline-partners :as costs]
            [energy-pnl.util.dates             :as dates]))

(def think-money-switch
  {:ref_level_1 "thinkmoney"
   :application :offline-partners})

(def month-switches
  [(dates/parse-date "2013-01-10") [think-money-switch
                                    {:ref_level_1 "winecase"
                                     :application :main-process}]])

(deftest given-month-switches-should-only-return-offline-partner-switches
  (is (= think-money-switch (-> month-switches
                                costs/switches-by-partner-and-day
                                :thinkmoney
                                vals
                                first))))
