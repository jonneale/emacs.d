(ns predictive-modelling.linear-regression)

(def alpha
  0.07)


(defn chart
  [data]
  (time-series-plot :date :count 
                    :x-label "Date"
                    :y-label "Switches"
                    :title "Count of switches by day"
                    :data data))


(defn data [filepath]
  (read-dataset filepath :header false))

(defn -main [& args]
  (let [[options args banner]
        (cli args
             ["-f" "--file" "Data file name (csv)"])]             

    (when (or (empty? options) (:help options))
      (println banner)
      (System/exit 0))
    (-> options
        :file
        data
        mod-data
        chart
        view)))