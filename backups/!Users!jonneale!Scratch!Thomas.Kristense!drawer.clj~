(ns image.drawer
  (:gen-class))

(declare inside?)


;; basic operations - knows about representation

(defn vectorize
  "Converts a nested sequence into nested vectors."
  [image]
  (vec (map vec image)))

(defn create
  "Creates a blank m x n image."
  [m n]
  (vectorize
   (for [x (range m)]
     (for [y (range n)]
       "O"))))

(defn width
  "Returns the width of image."
  [image]
  (count image))

(defn height
  "Returns the height of image."
  [image]
  (count (first image)))

(defn colour
  "Return the colour of the [x y]-position in image."
  [image pos]
  (get-in image pos))

(defn colour-pixel
  "Colours pos in image with c."
  [image pos c]
  (if (inside? image pos)
    (assoc-in image pos c)
    image))


;; helper functions

(defn- inside?
  "Return true if [x y] is inside the image."
  [image [x y]]
  (and (>= x 0) (< x (width image))
       (>= y 0) (< y (height image))))

(defn- colour-all-pixels
  "Colours all [x y] positions with c."
  [image positions c]
  (reduce #(colour-pixel %1 %2 c) image positions))

(defn- neighbours
  "Returns pixels in the image that share a common edge with the pixel
  at [x y]."
  [image [x y]]
  (filter
   (partial inside? image)
   [[(dec x) y]
    [(inc x) y]
    [x (dec y)]
    [x (inc y)]]))

(defn- same-colour?
  "Returns true if pos-1 and pos-2 have the same colour in image."
  [image pos-1 pos-2]
  (= (colour image pos-1) (colour image pos-2)))

(defn- same-colour-neighbours
  "Returns all neighbours to pos in image that are the same colour as
  pos."
  [image pos]
  (filter (partial same-colour? image pos) (neighbours image pos)))

(defn- region
  "Returns all positions that are in the region of pos in image. Two
  positions are in the same region if they are the same colour and
  there is a path of that colour from one to the other."
  ([image pos]
     ((fn [image front visited]
        (let [new-front (->> (map (partial same-colour-neighbours image) front)
                             (apply concat)
                             (filter (comp not visited))
                             (filter (comp not front))
                             set)
              new-visited (into visited front)]
          (if (seq new-front)
            (recur image new-front new-visited)
            new-visited)))
      image #{pos} #{})))


;; advanced operations, does not know representation

(defn clear
  "Clears the image."
  [image]
  (create (width image) (height image)))

(defn draw-vertical
  "Draws a line from [x y1] to [x y2] with c, both inclusive."
  [image x y1 y2 c]
  (colour-all-pixels image (for [y (range y1 (inc y2))] [x y]) c))

(defn draw-horizontal
  "Draws a line from [x1 y] to [x2 y] with c, both inclusive."
  [image x1 x2 y c]
  (colour-all-pixels image (for [x (range x1 (inc x2))] [x y]) c))

(defn fill
  "Fills the region with [x y] in it with c. Two positions are in the same
  region if they are the same colour and there is a path of that colour from
  one to the other."
  [image x y c]
  (colour-all-pixels image (region image [x y]) c))

(defn show
  "Prints image to standard out."
  [image]
  (println)
  (println "=>")
  (doseq [y (range (height image))]
    (doseq [x (range (width image))]
      (print (colour image [x y])))
    (println))
  (println))


;; command line tool

(defn convert-int
  "Converts s to an integer. Throws IllegalArgumentException if s does
  not represent an integer."
  [s]
  (try
    (Integer/parseInt s)
    (catch Exception e
      (throw (IllegalArgumentException. (str s " is not a number"))))))

(defn convert-pixel
  "Converts s to an integer and subtracts one, as pixels are one-indexed
  in the command-line tool. Throws IllegalArgumentException if s does
  not represent an integer."
  [s]
  (dec (convert-int s)))

(defn convert-char
  "Converts s to a char by extracting the first character."
  [s]
  (.charAt s 0))

(let [i convert-int
      p convert-pixel
      c convert-char]
  (def commands
    "A map from possible console commands to a vector containing
    [f & converters], where f is a function taking an image and
    a variable number of arguments, corresponding to the number
    of converters."
    {"I" [(fn [image m n] (create m n))
          i i]
     "C" [clear]
     "L" [(fn [image x y c]
            (colour-pixel image [x y] c))
          p p c]
     "V" [draw-vertical p p p c]
     "H" [draw-horizontal p p p c]
     "F" [fill p p c]
     "S" [(fn [image]
            (show image)
            image)]
     "X" [(constantly nil)]}))

(defn map-fns
  "Evaluate each function on each value and return a seq of the result."
  [fns vals]
  (map #(%1 %2) fns vals))

(defn get-command-function
  "Returns the function corresponding to the command along with converted
  versions of the str-args."
  [command & str-args]
  (when-let [[f & converters] (commands command)]
    (if (= (count str-args) (count converters))
      (cons f (map-fns converters str-args))
      (throw (IllegalArgumentException.
              (str "Expected " (count converters) " arguments"))))))

(defn executor-fn
  "Returns a function that takes command lines and perform side effects
  on image-atom according to these, using get-command-function to look
  up which functions to execute."
  [image-atom]
  (fn [line]
    (let [tokens (.split line " ")]
      (try
        (if-let [[f & args] (apply get-command-function tokens)]
          (apply swap! image-atom f args)
          (println "Unknown command"))
        (catch IllegalArgumentException e
          (println (.getMessage e)))))))


;; main loop

(defn -main
  "Repeatedly asks for input until the command \"X\" is given."
  [& args]
  (let [current-image (atom (create 0 0))
        executor (executor-fn current-image)]
    (while @current-image
      (print "> ")
      (flush) ;; unfinished lines must be flushed explicitly
      (when-let [line (read-line)]
        (executor line)))))


;; alternative executor-fn implementation using core.match
;; shorter and more conceice

(comment
  [org.clojure/core.match "0.2.0-alpha11"]
  (:use [clojure.core.match :only [match]])
  (let [i convert-int
        p convert-pixel
        ch convert-char]
    (defn executor-fn
      [image-atom]
      (fn [line]
        (let [tokens (vec (.split line " "))]
          (match
           [tokens]
           [["I" m n]]       (reset! image-atom (create (i m) (i n)))
           [["C"]]           (swap! image-atom clear)
           [["L" x y c]]     (swap!
                              image-atom
                              colour-pixel [(p x) (p y)] (ch c))
           [["V" x y1 y2 c]] (swap!
                              image-atom
                              draw-vertical (p x) (p y1) (p y2) (ch c))
           [["H" x1 x2 y c]] (swap!
                              image-atom
                              draw-horizontal (p x1) (p x2) (p y) (ch c)) 
           [["F" x y c]]     (swap! image-atom fill (p x) (p y) (ch c))
           [["S"]]           (show @image-atom)
           [["X"]]           (reset! image-atom nil)))))))