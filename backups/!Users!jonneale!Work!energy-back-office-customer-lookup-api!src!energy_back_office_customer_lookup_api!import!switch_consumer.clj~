(ns energy-back-office-customer-lookup-api.import.switch-consumer
  (:require
   [langohr.core                                             :as rmq]
   [langohr.channel                                          :as lch]
   [langohr.queue                                            :as lq]
   [langohr.consumers                                        :as lc]
   [langohr.basic                                            :as lb]
   [clojure.data.json                                        :as json]
   [energy-back-office-customer-lookup-api.config.config     :as config]
   [energy-back-office-customer-lookup-api.import.etl        :as etl])
  (:use     [korma.core]
            [clojure.pprint]
            [energy-back-office-customer-lookup-api.db.entities])
  (:gen-class))

(defn- pipe
  []
  (let [q (java.util.concurrent.LinkedBlockingQueue.)
        EOQ (Object.)
        NIL (Object.)
        s (fn s [] (lazy-seq (let [x (.take q)]
                               (when-not (= EOQ x)
                                 (cons (when-not (= NIL x) x) (s))))))]
    [(s) (fn ([] (.put q EOQ)) ([x] (.put q (or x NIL))))]))


(def ^{:const true}
  default-exchange-name "")

(defn- insert-switch
  [switch]
  (exec-raw ["INSERT INTO switches
              values (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)" switch]))

(defn payload-str
  [payload]
  (String. payload "UTF-8"))

(defn subscriber-seq
  [ch qname]
  (let [[message-seq put] (pipe)]
    (letfn [(message-handler [ch msg-meta payload]
              (put {:ch ch :msg-meta msg-meta :payload payload}))]
      (lc/subscribe ch qname message-handler :auto-ack true))
    message-seq))

(defn store-switch-data
  [message]
  (-> message
      :payload
      payload-str
      (json/read-str :key-fn keyword)
      vector
      etl/transform-data
      first
      insert-switch))

(defn start-consumer
  []
  (let [conn  (rmq/connect config/rabbit-mq)
        ch    (lch/open conn)
        ename "switches-received"
        q (.getQueue (lq/declare ch "" :exclusive false :auto-delete true))]
    (lq/bind ch q ename)
    (doall (map
            store-switch-data
            (subscriber-seq ch q)))))

(defn -main
  [& args]
  (let [thread (Thread. start-consumer)]
    (.start thread)))