(ns energy-switch-recon.updates.british-gas.load-on-supply-report
  ((:require [dk.ative.docjure.spreadsheet             :as spr]
             [energy-switch-recon.updates.load-updates :as updates]
             [clj-time.coerce                          :as coerce]
             [energy-switch-recon.dates                :as dates]
             [energy-switch-recon.util.format          :as format])
   (:use [clojure.tools.cli :only (cli)]
         [energy-switch-recon.db.db-entities]
         [korma.db]
         [korma.core])))

(defn- remove-blank-rows
  [data]
  (filter #(some (comp not nil?) 
                 (map val %)) data))

(defn nullable-date
  [date]
  (if date
    (dates/format-iso-date (coerce/from-date date))
    "\\N"))

(defn load-sheet
  [report-path]
  (->> (spr/load-workbook report-path)
       spr/sheet-seq
       (#(nth % 2))
       (spr/select-columns {:A :week-no
                            :B :supply-start-date
                            :C :gain-date
                            :D :product
                            :E :sales-ref
                            :F :mprn
                            :G :contact-first-name
                            :H :contact-last-name
                            :I :house-num
                            :J :house-name
                            :K :postcode
                            :L :x-ucrn-num
                            :M :payment-type
                            :N :media-code
                            :O :sales-channel-subset
                            :R :tariff
                            :S :email})
       (drop 1)
       remove-blank-rows))

(defn to-csv-data
  [report-data report-name]
  (reduce #(conj %1 [0
                     (:week-no %2)
                     (nullable-date (:supply-start-date %2))
                     (nullable-date (:gain-date %2))
                     (:product %2)
                     (:sales-ref %2)
                     (:mprn %2)
                     (:contact-first-name %2)
                     (:contact-last-name %2)
                     (:house-num %2)
                     (:house-name %2)
                     (format/lowercase-remove-spaces (:postcode %2))
                     (:x-ucrn-num %2)
                     (:payment-type %2)
                     (:media-code %2)
                     (:sales-channel-subset %2)
                     (:tariff %2)
                     (:email %2)
                     report-name
                     "\\N"]) [] report-data))

(defn load-statement
  [report-path]
  (-> report-path
      load-sheet
      (updates/load-into-db report-path british_gas_on_supply to-csv-data "british-gas")))

(defn -main [& args]
  (let [[options args banner] (cli args
                                   ["-f"  "--filepath" "The full path to the commision statement to load"]
                                   )]
    (when (or (:help options)
              (not (:filepath options)))
      (println banner)
      (System/exit 0))    
    (println "Reading report from: " (options :filepath))
    (load-statement (options :filepath) password)))
