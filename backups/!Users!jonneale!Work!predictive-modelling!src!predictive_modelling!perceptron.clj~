(ns predictive-modelling.perceptron
  (:gen-class))

(defn initialise-network
  []
  [(rand) (rand)])


(defn feed-forward
  [input weights]
  (reduce + (map-indexed (fn [index item] (* item (nth weights index))) input)))


(defn calculate-squared-error
  [result target]
  (Math/pow (- target result) 2))

;; 'and' problem
;; x y target
(def and-inputs
  [[1 1 1]
   [0 0 0]
   [0 1 0]
   [1 0 0]])

(defn train-network
  [weights all-inputs]
  (reduce (fn [summed-squared-error input]
            (+ summed-squared-error
               (-> input
                   (feed-forward weights)
                   (calculate-squared-error (last input)))))
          0
          all-inputs)
  ;; (dotimes [i 100000]
  ;; 
  )

(defn run-network
  []
  (-> initialise-network
      (train-network and-inputs)))