(ns predictive-modelling.visualise
  (:use [clojure.tools.cli :only (cli)]
        [incanter core stats charts])
  )

(defn -main [& args]
  (let [[options args banner]
        (cli args
             ["-h" "--help" "Show help"]
             ["-n" "--number-of-days" "The number of days to import for, e.g for 5 it will import switches from 5, 4, 3, 2 and 1 days ago"]
             ["-sd" "--start-date" "The date to start the import from switch-managment, e.g 2012-04-12"]
             ["-ed" "--end-date" "Date at which the import should stop, e.g 2012-04-13"]
             ["-s" "--supplier-name-key" "The supplier name key to import switches for (optional)" :optional true]
             ["-p" "--[no-]phone-numbers-only" :default false])]             
    (when (or (empty? options) (:help options))
      (println banner)
      (System/exit 0))

    (let [end-date (calculate-end-date options)
          num-days (calculate-number-of-days options)
          supplier-name-key (:supplier-name-key options)
          import-fn (if (:phone-numbers-only options) import-phone-numbers-only import-switches)]
      (->> end-date
           (iterate dates/previous-day)
           (take num-days)
           (map #(import-fn % supplier-name-key))))))