(ns supplier-data.suppliers.eon.acquisition-filter
  )

(defn- acquisition-switch?
  [switch]
  (let [instruction (:instruction switch)]
    (cond (= :dual-fuel (si/new-plan-type instruction))
          (let [elec-supplier-name-key (si/get-current-electricity-supplier-name-key instruction)
                gas-supplier-name-key (si/get-current-gas-supplier-name-key instruction)]
            (and (not (edf-group-supplier? gas-supplier-name-key)) (not (edf-group-supplier? elec-supplier-name-key))))

          (= :electricity (si/new-plan-type instruction))
          (let [elec-supplier-name-key (si/get-current-electricity-supplier-name-key instruction)]
            (not (edf-group-supplier? elec-supplier-name-key)))

          (= :gas (si/new-plan-type instruction))
          (let [gas-supplier-name-key (si/get-current-gas-supplier-name-key instruction)]
            (not (edf-group-supplier? gas-supplier-name-key))))))