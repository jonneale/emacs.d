(defn get-wrapped-cell-position
  [row-position column-position offset grid]
  (let [row-pos (+ row-position (:row offset))
        col-pos (+ column-position (:column offset))
        wrapped-row-pos (cond (< row-pos 0) 
                              (- (count grid) 1)
                              (> row-pos (- (count grid) 1))
                              0
                              :else
                              row-pos)
        wrapped-col-pos (cond (< col-pos 0) 
                              (- (count (first grid)) 1)
                              (> col-pos (- (count (first grid)) 1))
                              0
                              :else
                            col-pos)]
        {:row wrapped-row-pos
         :col wrapped-col-pos}))
         
        
(defn update-cell
  [cell row-position column-position grid]
  (let [offsets (remove nil? (for [row-offset (range -1 2) column-offset (range -1 2)] 
															(when (or (not= 0 row-offset) (not= 0 column-offset)) {:row row-offset :column column-offset})))
				neighbour-cells (map #(get-wrapped-cell-position row-position column-position % grid) offsets)  
        neighbours (map #(nth (nth grid (:col %)) (:row %)) neighbour-cells)
        neighbour-count (count (filter #(= \# %) neighbours))
        ]
				(if (= cell \#)
					(or (= neighbour-count 2)
              (= neighbour-count 3))
          (= neighbour-count 3))))

(defn modify-row
  [row row-position grid]
  (map-indexed (fn[column-position cell] (update-cell cell row-position column-position grid)) row))

(defn run [g]
  (map (fn[row] (apply str (map #(if % "#" " ") row)))
           (map-indexed (fn[position row] (modify-row row position g)) g) ) )